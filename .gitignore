# Local environment and secrets
.env
.env.*
.env-deploy
!.env.example

# Dependency directories
vendor/
node_modules/

# Runtime state
storage/installed.lock
storage/logs/*
storage/temp/*
storage/mail/*
storage/certificates/*
storage/fonts/*

# Public uploads generated by the application
apps/admin/public/uploads/*
apps/earner/public/uploads/*

# Keep access-control files in otherwise ignored runtime directories
!storage/.htaccess
!storage/logs/.htaccess
!storage/temp/.htaccess
!storage/mail/.htaccess
!storage/certificates/.htaccess
!storage/fonts/.htaccess
!apps/admin/public/uploads/.htaccess
!apps/earner/public/uploads/.htaccess

# Logs and temporary files
_seed.php
*.log
*.tmp
*.temp
*.swp
*.swo

# OS and editor metadata
.DS_Store
Thumbs.db
.idea/
.vscode/

# Agent/local assistant state
.agents/
.codex/
.claude/
.hexflaw/
