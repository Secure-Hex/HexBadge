# App
APP_NAME=HexBadge
APP_URL=https://badges.securehex.cl
APP_ENV=production         # production | development
APP_DEBUG=false
APP_SECRET=                # Generar con: php -r "echo bin2hex(random_bytes(32));"

# Base de datos
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=hexbadge
DB_USER=hexbadge_user
DB_PASS=
DB_CHARSET=utf8mb4

# Email (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@securehex.cl
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME=SecureHex Badges
MAIL_FROM_ADDRESS=noreply@securehex.cl

# Upload
UPLOAD_MAX_SIZE_MB=2
UPLOAD_PATH=public/uploads/badges/

# Rate limiting
RATE_LIMIT_LOGIN=5          # intentos por ventana
RATE_LIMIT_LOGIN_WINDOW=900 # 15 minutos en segundos
RATE_LIMIT_API=100          # requests por minuto
RATE_LIMIT_VERIFY=30        # requests por minuto (verificación pública)
RATE_LIMIT_CSV=3            # uploads por hora
